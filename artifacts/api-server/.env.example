# @workspace/api-server — environment

# Postgres connection string (required).
DATABASE_URL=postgres://user:pass@localhost:5432/growpod

# Shared admin key for the temporary /api/plant/* guard (x-admin-key header)
# until wallet-signature auth ships. Fail-closed: routes 503 if unset.
ADMIN_KEY=

# --- Chain service bridge (CLONE-10) ----------------------------------------
# The on-chain ASA mint happens at plant time via the Python chain service.
# When CHAIN_SERVICE_URL is set, seed minting POSTs to
# `${CHAIN_SERVICE_URL}/api/chain/mint-seed` with the X-API-Key below; when it
# is unset, an offline mock client is used so dev/CI need no chain or key.
CHAIN_SERVICE_URL=
# Must match the Python service's ADMIN_SECRET.
CHAIN_SERVICE_API_KEY=
