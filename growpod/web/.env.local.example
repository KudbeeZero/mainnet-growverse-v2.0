# Base URL of the GROWv2 Flask API. The client appends /api/game itself.
NEXT_PUBLIC_API_BASE=http://localhost:10000

# --- MVP feature flags ------------------------------------------------------
# Non-MVP systems are OFF by default (the launch build shows only the core grow
# loop). Set a flag to "true" to surface that system's nav entry + routes. These
# must match the backend's ENABLE_* env vars (src/growpodempire/config.py).
NEXT_PUBLIC_ENABLE_MARKETPLACE=false
NEXT_PUBLIC_ENABLE_CHAIN=false
NEXT_PUBLIC_ENABLE_CUP=false
NEXT_PUBLIC_ENABLE_UNIVERSITY=false
NEXT_PUBLIC_ENABLE_CONTRACTS=false
