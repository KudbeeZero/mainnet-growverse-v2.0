# Base URL of the GROWv2 Flask API. The client appends /api/game itself.
NEXT_PUBLIC_API_BASE=http://localhost:10000

# --- MVP feature flags ------------------------------------------------------
# Non-MVP systems are OFF by default (the launch build shows only the core grow
# loop). Set a flag to "true" to surface that system's nav entry + routes. These
# must match the backend's ENABLE_* env vars (src/growpodempire/config.py).
NEXT_PUBLIC_ENABLE_MARKETPLACE=false
NEXT_PUBLIC_ENABLE_CHAIN=false
NEXT_PUBLIC_ENABLE_CUP=false
NEXT_PUBLIC_ENABLE_UNIVERSITY=false
NEXT_PUBLIC_ENABLE_CONTRACTS=false

# --- Arcade Mode ------------------------------------------------------------
# Procedural Web Audio FX for the chamber boosts. Off by default (and muted under
# prefers-reduced-motion). No audio files are shipped.
NEXT_PUBLIC_ARCADE_SOUND=false

# --- Algorand TestNet (client chain layer) ----------------------------------
# Best-effort, non-blocking. DB stays authoritative; the chain is a mirror.
# ENABLE=false makes the entire chain layer a no-op (no wallet/mint UI, algosdk
# stays out of the bundle). SIMULATE=true (default) logs the JSON payload to the
# console and sends NO real transactions — flip to "false" only with a funded
# wallet to broadcast on TestNet. No mnemonic/secret is read here: real signing is
# via Pera Wallet (user holds keys); the "Dev" option uses an ephemeral in-memory
# account for local testing only.
NEXT_PUBLIC_ALGO_ENABLE=true
NEXT_PUBLIC_ALGO_SIMULATE=true
NEXT_PUBLIC_ALGO_NETWORK=testnet
NEXT_PUBLIC_ALGO_NODE_URL=https://testnet-api.algonode.cloud
NEXT_PUBLIC_ALGO_INDEXER_URL=https://testnet-idx.algonode.cloud
NEXT_PUBLIC_ALGO_NODE_TOKEN=""
