# Keep the build context small and ensure no secrets/dev artifacts leak into the
# image. The Dockerfile copies only what gunicorn needs (server.py, alembic*,
# src/); this is belt-and-suspenders.

# Python build/test artifacts
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.coverage
.coverage.*
htmlcov/
*.egg-info/

# Local SQLite DBs (production uses Postgres via DATABASE_URL)
*.db
*.db-wal
*.db-shm

# Secrets — never bake into an image
.env
.env.*
!.env.example

# Frontend (deployed separately via Cloudflare Pages) + Node tooling
web/
node_modules/
lib/
artifacts/
scripts/
pnpm-lock.yaml
pnpm-workspace.yaml
package.json
.npmrc
tsconfig*.json

# Docs / dev notes (not needed at runtime)
docs/
night-reports/
knowledge/
attached_assets/
*.md

# VCS / agent tooling
.git/
.github/
.claude/
.agents/
