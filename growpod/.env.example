# Configuration for GROWv2. Copy to .env and customize. Every value here has a
# sensible default in code, so .env is optional for local dev.

# Server: the port is injected by the host (Render) in production; FLASK_DEBUG
# must be left false outside local development.
# PORT=10000
# FLASK_DEBUG=false

# Database Configuration
# Local/dev default is SQLite; production (Render) injects a Postgres URL.
DATABASE_URL=sqlite:///growpod.db
# Example Postgres: DATABASE_URL=postgresql://user:pass@host:5432/growpod

# Economy / game data (override only to point at custom balance files)
# BALANCE_FILE=src/growpodempire/data/balance.yaml
# STRAINS_FILE=src/growpodempire/data/strains.yaml

# Optional fixed RNG seed for reproducible breeding (leave unset in production)
# RNG_SEED=

# Set to true to echo SQL for debugging
# SQL_ECHO=false

# --- Security / hardening --------------------------------------------------
# Comma-separated browser origins allowed to call the API (CORS). Set to your
# deployed web origin in production. Avoid "*".
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Rate limiting. Use a Redis URI in production so limits hold across workers.
# RATELIMIT_ENABLED=true
# RATELIMIT_STORAGE_URI=memory://
# RATELIMIT_DEFAULT=240 per minute
# Cap on-chain withdrawals per player per rolling 24h (0 disables the cap).
# MAX_WITHDRAWAL_PER_DAY=10000

# --- Daily snapshot (scripts/snapshot.py) ----------------------------------
# SNAPSHOT_DIR=snapshots
# SNAPSHOT_RETENTION_DAYS=30

# --- Algorand on-chain layer (Phase 3, not yet active) ---------------------
# Target TestNet first. Treasury mnemonic / encryption key are SECRETS — set
# them only in the host's secret store, never commit them.
# ALGOD_URL=https://testnet-api.algonode.cloud
# ALGOD_TOKEN=
# INDEXER_URL=https://testnet-idx.algonode.cloud
# ALGO_TREASURY_MNEMONIC=
# WALLET_ENCRYPTION_KEY=
# ASA_ID=
# NFT_METADATA_BASE_URL=
# Force the offline mock chain even if a treasury is configured (tests/dev).
# USE_MOCK_CHAIN=false

# --- AI "Master Grower" advisor --------------------------------------------
# The advisor reads a plant's live state and recommends care actions. The
# ANTHROPIC_API_KEY is a SECRET — set it only in the host's secret store. With
# no key (or USE_MOCK_AI=true), an offline deterministic mock advisor is used,
# so the app and tests run with no key.
# ANTHROPIC_API_KEY=
# ADVISOR_MODEL=claude-opus-4-8
# USE_MOCK_AI=false
# Agentic auto-care lets the advisor call care actions itself within a per-run
# GROW budget + action cap (tuned in balance.yaml:auto_care). On by default.
# ENABLE_AUTO_CARE=true

# Feature flags: definitions + defaults live in balance.yaml (feature_flags:).
# Override any flag per-environment WITHOUT a deploy via FEATURE_<UPPER_NAME>
# (true/false/on/off/1/0). Resolved map is served at GET /api/game/flags.
# Examples (defaults are on):
# FEATURE_FTUE_TUTORIAL=true
# FEATURE_MARKETPLACE=true

# NOTE: all economy/simulation/growth tuning lives in
# src/growpodempire/data/balance.yaml, not in environment variables.
