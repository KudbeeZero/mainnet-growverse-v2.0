modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

# Build — runs once per deployment before the container starts
[deployment.build]
args = ["sh", "scripts/build-production.sh"]
env = { "CI" = "true" }

# Run — runs every time the container boots
[deployment.run]
args = ["sh", "scripts/start-production.sh"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "GrowPod Web"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "GrowPod API"

[[workflows.workflow]]
name = "GrowPod Web"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/growpod/web && npm run dev"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "GrowPod API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd /home/runner/workspace/growpod && DATABASE_URL='sqlite:////home/runner/workspace/growpod/growpod.db' USE_MOCK_AI=true USE_MOCK_CHAIN=true PYTHONPATH=src sh -c 'python3 -c \"from growpodempire.db.session import init_db; init_db()\" && python3 -m growpodempire.db.seed && python3 -m gunicorn server:app --bind 0.0.0.0:8000 --workers 2 --timeout 60'"
waitForPort = 8000

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["libxcrypt", "libyaml"]

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 8000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3001

[userenv]

[userenv.development]
GROW_TEST_CLOCK = "true"

[userenv.shared]
VITE_GROWPOD_APP_ID = "755243944"
VITE_BUD_ASSET_ID = "755243947"
VITE_TERP_ASSET_ID = "755243948"
VITE_SLOT_ASSET_ID = "755243949"
VITE_GROWPOD_APP_ADDRESS = "CWGAVWZRVKKFHRYZHEPQPELVJMFNW2QMIWNEB2H3ZXCKOXRIPKWCW2IBRI"
ADMIN_WALLET_ADDRESS = "HW6U3RKLOYEW2X2L4DERSJHBPG6G6UTKDWBSS2MKPZJOSAWKLP72NTIMNQ"
ALGORAND_ADMIN_MNEMONIC = "any virus dynamic mind figure glide shove peanut village grab wisdom film luggage shoulder fetch license tunnel daring lounge rubber eagle source inch able world"
